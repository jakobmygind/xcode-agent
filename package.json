{
  "name": "xcode-agent-runner",
  "version": "1.0.0",
  "description": "Ticket-driven AI agent system for iOS development with real-time streaming",
  "type": "module",
  "scripts": {
    "start": "tsx src/router.ts",
    "worker": "tsx src/worker.ts",
    "bridge": "tsx src/bridge.ts",
